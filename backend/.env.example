# ═══════════════════════════════════════════════════════════════
# Bright Data Configuration
# ═══════════════════════════════════════════════════════════════
BRIGHT_DATA_API_TOKEN=your_bright_data_api_token_here

# Zone credentials (found in Bright Data dashboard → zone settings)
BRIGHT_DATA_SERP_USERNAME=your_serp_zone_username
BRIGHT_DATA_SERP_PASSWORD=your_serp_zone_password

BRIGHT_DATA_UNLOCKER_USERNAME=your_web_unlocker_zone_username
BRIGHT_DATA_UNLOCKER_PASSWORD=your_web_unlocker_zone_password

BRIGHT_DATA_BROWSER_AUTH=your_scraping_browser_auth
BRIGHT_DATA_BROWSER_HOST=brd.superproxy.io:9515

# Web Scraper API
BRIGHT_DATA_SCRAPER_TOKEN=your_api_token_here

# ═══════════════════════════════════════════════════════════════
# AI/ML API Configuration (Partner Challenge)
# ═══════════════════════════════════════════════════════════════
AIML_API_KEY=your_aiml_api_key_here
AIML_API_BASE_URL=https://api.aimlapi.com/v1

# ═══════════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════════
SCAN_INTERVAL_HOURS=6
ALERT_THRESHOLD_SCORE=7.0
DATABASE_URL=sqlite:///./vendorsentinel.db
FRONTEND_URL=http://localhost:5173
